# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/farmcoop"

# ── Auth & Security ──────────────────────────────────────
API_KEY="change-me-in-production"
NEXT_PUBLIC_API_KEY="change-me-in-production"

# Discord OAuth — https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_client_id
DISCORD_CLIENT_SECRET=your_client_secret

# Optional: Discord webhook for notifications
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── Bridge Service ───────────────────────────────────────
BRIDGE_TRANSPORT=local           # "local" or "ftp"
BRIDGE_API_URL=http://localhost:3000
BRIDGE_POLL_INTERVAL_MS=5000

# Local transport (default: ~/Documents/My Games/FarmingSimulator2025/modSettings/FS25_FarmCoop)
# BRIDGE_MOD_SETTINGS_PATH=/path/to/modSettings/FS25_FarmCoop

# FTP transport (required when BRIDGE_TRANSPORT=ftp)
# BRIDGE_FTP_HOST=your.ftp.host
# BRIDGE_FTP_PORT=21
# BRIDGE_FTP_USER=your_ftp_user
# BRIDGE_FTP_PASSWORD=your_ftp_password
# BRIDGE_FTP_SECURE=false
# BRIDGE_FTP_REMOTE_PATH=/path/to/modSettings/FS25_FarmCoop
